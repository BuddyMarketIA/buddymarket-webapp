<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ── Capacitor ─────────────────────────────────────────── -->
	<key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>

	<!-- ── Bundle Identity ───────────────────────────────────── -->
	<key>CFBundleDevelopmentRegion</key>
	<string>es</string>
	<key>CFBundleDisplayName</key>
	<string>BuddyMarket</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- ── Localizations ─────────────────────────────────────── -->
	<key>CFBundleLocalizations</key>
	<array>
		<string>es</string>
		<string>en</string>
		<string>fr</string>
		<string>it</string>
	</array>

	<!-- ── Device & Orientation ──────────────────────────────── -->
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- ── UI ────────────────────────────────────────────────── -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleLightContent</string>
	<key>UIUserInterfaceStyle</key>
	<string>Light</string>

	<!-- ── App Transport Security ────────────────────────────── -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<key>buddymarketapp.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<false/>
				<key>NSIncludesSubdomains</key>
				<true/>
			</dict>
		</dict>
	</dict>

	<!-- ── Privacy Permissions ───────────────────────────────── -->
	<!-- Cámara: para escanear códigos de barras de alimentos -->
	<key>NSCameraUsageDescription</key>
	<string>BuddyMarket usa la cámara para escanear códigos de barras de productos alimentarios y añadirlos automáticamente a tu inventario o lista de la compra.</string>

	<!-- Librería de fotos: para subir foto de perfil -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>BuddyMarket accede a tus fotos para que puedas personalizar tu foto de perfil.</string>

	<!-- Librería de fotos (escritura): para guardar imágenes de recetas -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>BuddyMarket puede guardar imágenes de recetas en tu galería de fotos.</string>

	<!-- Notificaciones push: para recordatorios de comidas y alertas -->
	<!-- (los permisos de notificación se solicitan en tiempo de ejecución) -->

	<!-- Localización: para encontrar supermercados cercanos -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>BuddyMarket usa tu ubicación para mostrarte los supermercados más cercanos y comparar precios en tu zona.</string>

	<!-- Face ID / Touch ID: para acceso rápido seguro -->
	<key>NSFaceIDUsageDescription</key>
	<string>BuddyMarket usa Face ID para que puedas acceder a tu cuenta de forma rápida y segura.</string>

	<!-- ── URL Schemes (Sign in with Apple, Google OAuth) ─────── -->
	<key>CFBundleURLTypes</key>
	<array>
		<!-- Google OAuth callback (URL scheme = reversed Client ID) -->
		<dict>
			<key>CFBundleURLName</key>
			<string>com.buddymarket.app.google</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.909562975875-l71herhk1vbmv8t6alqpjgr5b110novv</string>
			</array>
		</dict>
		<!-- Deep link scheme -->
		<dict>
			<key>CFBundleURLName</key>
			<string>com.buddymarket.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>buddymarket</string>
			</array>
		</dict>
	</array>

	<!-- ── Associated Domains (Universal Links + Sign in with Apple) -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:buddymarketapp.com</string>
		<string>webcredentials:buddymarketapp.com</string>
	</array>

	<!-- ── Background Modes ───────────────────────────────────── -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>

	<!-- ── iTunes / App Store metadata ──────────────────────────  -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
